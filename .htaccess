Options -Indexes

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self'; frame-src https://drive.google.com https://docs.google.com; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" "expr=%{HTTPS} == 'on'"
</IfModule>

<FilesMatch "(^\.|env\.php$|composer\.(json|lock)$|package(-lock)?\.json$|.*\.(sql|bak|log|ini|sh|ps1|md)$)">
  Require all denied
</FilesMatch>

RedirectMatch 404 "(^|/)(\.git|\.idea|config|database|scripts|BurnoutTheme|prueba_piloto)(/|$)"
